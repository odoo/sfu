# Copy this file to .env and fill in your values

# ── Required ────────────────────────────────────────────────────
# Public IP address used to establish WebRTC connections
# Must be reachable by clients - do NOT use 127.0.0.1 / loopback.
# For local dev: use device's LAN IP
# For prod: the server's public IP
PUBLIC_IP=example.com

# Base64-encoded auth key — generate with: openssl rand -base64 32
AUTH_KEY=

# ── HTTP/WebSocket ──────────────────────────────────────────────
PORT=8070
# HTTP_INTERFACE=0.0.0.0
# PROXY=1                # set if behind a reverse proxy

# ── WebRTC ──────────────────────────────────────────────────────
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
# RTC_INTERFACE=0.0.0.0

# ── Codecs (comma-separated, defaults to all available) ────────
# AUDIO_CODECS=opus,PCMU,PCMA
# VIDEO_CODECS=VP8,VP9,H264,H264_1_2c,H264_1_3ch

# ── Limits ──────────────────────────────────────────────────────
# CHANNEL_SIZE=100
# MAX_BITRATE_IN=8000000
# MAX_BITRATE_OUT=10000000
# MAX_VIDEO_BITRATE=4000000

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TIMESTAMP=true
# LOG_COLOR=1
# WORKER_LOG_LEVEL=warn
# DEBUG=mediasoup*

